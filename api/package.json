{
  "name": "starslab-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev src/site-worker.ts --port 3001",
    "deploy": "wrangler deploy --minify src/site-worker.ts",
    "db:generate": "drizzle-kit generate:sqlite",
    "db:migrate": "wrangler d1 migrations apply starslab-db",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@hono/zod-validator": "^0.2.1",
    "@noble/hashes": "^2.0.0",
    "@noble/secp256k1": "^3.0.0",
    "@scure/bip32": "^2.0.0",
    "@scure/bip39": "^2.0.0",
    "drizzle-orm": "^0.29.3",
    "ethers": "^6.15.0",
    "hono": "^4.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "@types/node": "^20.11.5",
    "drizzle-kit": "^0.20.12",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "wrangler": "^4.32.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
